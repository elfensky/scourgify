# Personal review maps & intermediates — derived from YOUR Calibre library.
# Ignore ALL CSVs by default; the bundled generic defaults/ are the only tracked CSVs.
*.csv
!defaults/*.csv

# Calibre DB snapshots / backups
*.db

# Generated per-user config is fine to ship as a default, but ignore local overrides
overrides/

# Python / OS cruft
__pycache__/
*.pyc
.DS_Store
